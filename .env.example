# --------------------------------------------------------------------------
# MBK Holding Commodities — Environment Configuration
# Copy this file to .env.local and fill in approved values.
# Never commit real secrets to source control.
# --------------------------------------------------------------------------

# Public base URL used for canonical links, sitemap and Open Graph tags.
# APPROVED — production domain confirmed as https://mbkcommodities.com.
# This value also gates search-engine indexing (see lib/metadata.ts,
# isConfirmedProductionDomain) — indexing only turns on when this exact
# URL is what's actually being served from.
NEXT_PUBLIC_SITE_URL=https://mbkcommodities.com

# --------------------------------------------------------------------------
# Contact form — email delivery (Resend only)
# --------------------------------------------------------------------------
# Production Recovery: this is now a minimal, direct integration —
# implemented in lib/email-provider.ts, called via plain HTTPS fetch (no
# SDK dependency, no provider-selection abstraction, no demo-mode
# fallback). Resend is the only supported path. If RESEND_API_KEY or
# RESEND_FROM_EMAIL is missing, every submission throws immediately —
# there is no non-production fallback anymore.
#
# RESEND_FROM_EMAIL must be an address on a domain you have verified in
# your Resend account (Resend rejects sends from unverified domains). Do
# not use a free/sandbox address for real production delivery.
#
# Every submission sends two emails: an internal notification to
# CONTACT_INTERNAL_NOTIFICATION_EMAILS (comma-separated), then an
# automatic acknowledgement to the visitor's own submitted email address.
#
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# CONTACT_INTERNAL_NOTIFICATION_EMAILS=haluk@mbkholding.qa,tariq@mbkholding.qa
# (defaults to the two addresses above if left unset — override only if
# the reviewing team's addresses change.)

# --------------------------------------------------------------------------
# Rate limiting — removed (Production Recovery)
# --------------------------------------------------------------------------
# The contact form previously used a Redis-backed rate limiter (Upstash).
# It has been removed entirely as part of a deliberate production
# simplification — see content/placeholders.ts, "contact-form-production-readiness".
# No RATE_LIMIT_PROVIDER or UPSTASH_* variables are read by the code anymore.

# --------------------------------------------------------------------------
# Corporate contact details
# --------------------------------------------------------------------------
# CONTACT_EMAIL below is a TEMPORARY DEVELOPMENT PLACEHOLDER, not the final
# production address — safe for local testing and current site display,
# but not to be assumed final. Deliberately not a launch blocker on its
# own. Telephone and LinkedIn remain unset — until MBK approves those,
# their rows are omitted from the public site rather than shown as
# placeholders. See content/contact.ts and content/placeholders.ts.
CONTACT_EMAIL=info@mbkcommodities.qa
# CONTACT_TELEPHONE=
# CONTACT_LINKEDIN_URL=
